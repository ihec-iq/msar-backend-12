# Environment Configuration Template for Laravel Deployment
# Copy this file as .env and fill in your values

# Application Environment
APP_NAME="Laravel Application"
APP_ENV=production
APP_KEY=base64:xxx
APP_DEBUG=false
APP_URL=https://example.com

# Port Configuration
PORT=8000

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=mysql.default.svc.cluster.local
DB_PORT=3306
DB_DATABASE=laravel_database
DB_USERNAME=laravel_user
DB_PASSWORD=secure_password

# Cache Configuration
CACHE_DRIVER=redis
CACHE_HOST=redis.default.svc.cluster.local
CACHE_PORT=6379

# Queue Configuration
QUEUE_CONNECTION=redis
REDIS_HOST=redis.default.svc.cluster.local
REDIS_PORT=6379

# Session Configuration
SESSION_DRIVER=redis

# Mail Configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_password
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Logging Configuration
LOG_CHANNEL=stack
LOG_LEVEL=notice

# AWS Configuration (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Supervisor Configuration
SUPERVISOR_ENABLE_QUEUE=false

# PHP Configuration (via environment)
PHP_MEMORY_LIMIT=256M
PHP_MAX_EXECUTION_TIME=300
PHP_UPLOAD_MAX_FILESIZE=30M
PHP_POST_MAX_SIZE=35M
